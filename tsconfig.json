{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "outDir": "./dist"
  },
  "include": [
    "assets/components/mxeditorjs/js/src/**/*.ts",
    "assets/components/mxeditorjs/js/src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
